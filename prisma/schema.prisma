// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// Banco Global: Tenants
model Tenant {
  id              String   @id @default(uuid())
  slug            String   @unique
  nome            String
  proprietario_nome String?
  nicho           String   @default("beleza")
  whatsapp_numero String   @unique
  turso_db_url    String   @default("")
  turso_db_token  String   @default("")
  plano           String   @default("starter")
  api_key         String   @unique @default(uuid())
  instancia        String   @default("default")
  template        String   @default("manicure1")
  endereco        String?
  logo_url        String?
  instagram_url   String?
  facebook_url    String?
  horario_funcionamento String? // JSON string
  ativo           Boolean  @default(true)
  criado_em       DateTime @default(now())
}

// Estrutura para os bancos de cada Tenant (usaremos o mesmo schema para simplicidade)
model Servico {
  id                String        @id @default(uuid())
  nome              String
  duracao_min       Int
  preco             Float
  descricao         String?
  ativo             Boolean       @default(true)
  profissionais_ids String        @default("[]")
  criado_em         DateTime      @default(now())
  atualizado_em     DateTime      @updatedAt
  agendamentos      Agendamento[]
}

model Profissional {
  id               String   @id @default(uuid())
  nome             String
  especialidades   String
  horarios         String
  ativo            Boolean  @default(true)
  comissao_tipo    String?  // "fixo" | "porcentagem"
  comissao_valor   Float?
  criado_em        DateTime @default(now())
  atualizado_em    DateTime @updatedAt
  agendamentos     Agendamento[]
  pagamentos_comissao ComissaoPagamento[]
}

model Cliente {
  telefone           String   @id
  nome               String?
  total_visitas      Int      @default(0)
  ultimo_agendamento String?
  servicos_favoritos String?  // JSON string
  criado_em          DateTime @default(now())
  agendamentos       Agendamento[]
}

model Agendamento {
  id              String   @id @default(uuid())
  cliente_tel     String
  cliente         Cliente  @relation(fields: [cliente_tel], references: [telefone])
  servico_id      String
  servico         Servico  @relation(fields: [servico_id], references: [id])
  profissional_id String
  profissional    Profissional @relation(fields: [profissional_id], references: [id])
  inicio          DateTime
  fim             DateTime
  status          String   @default("confirmado") // confirmado | cancelado | realizado | falta
  origem          String   @default("whatsapp_ia")
  observacoes     String?
  nps             Int?     // 0-10
  criado_em       DateTime @default(now())
}

model Config {
  chave String @id
  valor String
}

model ComissaoPagamento {
  id              String       @id @default(uuid())
  profissional_id String
  profissional    Profissional @relation(fields: [profissional_id], references: [id])
  mes             Int
  ano             Int
  valor_total     Float
  pago_em         DateTime     @default(now())
  observacao      String?
}

model VerificationCode {
  id        String   @id @default(uuid())
  whatsapp  String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid())
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

